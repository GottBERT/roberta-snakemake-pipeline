configfile: "config.yaml"

# from iso639 import languages
import os

def output(file, output_dir = config['dir_output']):
  return os.path.join(output_dir, file)

rule all:
  input: 
    clean=output("filtered.txt"),
    fail=output("trash/langdetect.txt"),
    doc_count=output("count.txt"),
    dirt_svm=output("trash/svm.txt"),
    dirt_filter=output("trash/filter.txt")

rule compile_rust:
  output: 
    langdetect="scripts/langdetect/target/release/langdetect",
    compute_ratios="scripts/compute_ratios/target/release/compute_ratios"
  conda: "envs/rust.yaml"
  shell: r"""
    # using the conda installed linker
    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=x86_64-conda_cos6-linux-gnu-cc \
      cargo build --release --manifest-path scripts/langdetect/Cargo.toml
    
    CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=x86_64-conda_cos6-linux-gnu-cc \
      cargo build --release --manifest-path scripts/compute_ratios/Cargo.toml
  """

rule compute_ratio_test:
  output: 
    result=output(config["ratio_file_test"])
  input:
    compute_ratios_bin="scripts/compute_ratios/target/release/compute_ratios",
    txt=config["svm_txt_test"],
    stopwords=config["ratio_file_stop_words"]
  shell: r"""
    {input.compute_ratios_bin} --stop {input.stopwords} \
      --in {input.txt} --out {output.result}
  """

rule compute_ratio_train:
  output: 
    result=output(config["ratio_file_train"])
  input:
    compute_ratios_bin="scripts/compute_ratios/target/release/compute_ratios",
    txt=config["svm_txt_train"],
    stopwords=config["ratio_file_stop_words"]
  shell: r"""
    {input.compute_ratios_bin} --stop {input.stopwords} \
      --in {input.txt} --out {output.result}
  """
  

rule train_svm:
  input:
    test=output(config["ratio_file_test"]),
    train=output(config["ratio_file_train"]),
    gt=config["svm_file_gt"]
  output:
    model=output(config['svm_file_model']),
    metrics=output(config['svm_file_metrics']),
    log=output(config['svm_file_train_log'])
  conda: "envs/svm.yaml"
  shell: r"""
    scripts/train_SVM.py \
      --gt {input.gt} \
      --test {input.test} \
      --train {input.train} \
      --out {output.model} \
      --metrics {output.metrics} \
      --log {output.log} \
      --nu {config[svm_nu]} \
      --tol {config[svm_tol]} \
      --gamma {config[svm_gamma]} \
      --cache_size {config[svm_cache_size]}
  """

rule split_file:
  input: config['in_file']
  output: expand(output("tmp/split_{part}.txt"), part=range(1,config['num_files']+1))
  params:
    output=output("tmp/split_")
  shell: r"""
    # get lines of file
    if [[ {config[file_lines]} -gt 0 ]]; then
      total_lines={config[file_lines]}
    else
      total_lines=$(wc -l {config[in_file]} | cut -d" " -f1)
    fi

    # compute how many files to result the split to
    ((lines_per_file = (total_lines + {config[num_files]}) / ({config[num_files]})))

    # do the split
    split \
      --numeric-suffixes=1\
      --additional-suffix=".txt" \
      --lines=$lines_per_file "{config[in_file]}" "{params.output}"

    # rename files, i.e. form split_0001000.txt to split_1000.txt
    for file in {params.output}*
    do
      new_name=$(echo $file | sed -E 's/(.+_)0*([1-9].*)/\1\2/')
      
      if [[ ! -f $new_name ]]; then
        mv $file $new_name
      fi
    done
  """

rule filter_damaged_umlauts:
  input: output("tmp/split_{part}.txt")
  output: 
    filtered=temp(output("tmp/filtered_{part}.txt")),
    dirt=temp(output("tmp/filtered_{part}.dirt.txt"))
  shell: r"""
    cat {input} | awk 'length($0) < {config[min_tokens]}' > {output.dirt} || true
    cat {output.dirt} | grep -va '�' > {output.dirt} || true
    cat {input} | grep -a '�' >> {output.dirt} || true
    cat {input} | awk 'length($0) >= {config[min_tokens]}' | grep -va '�' > {output.filtered} || true
  """

rule clean_content:
  input: output("tmp/filtered_{part}.txt")
  output: output("tmp/clean_{part}.txt")
  conda: "envs/clean.yaml"
  shell: r"""
    scripts/clean_text.py -i {input} -o {output}
  """

rule filter_language:
  input: 
    bin="scripts/langdetect/target/release/langdetect",
    data=output("tmp/clean_{part}.txt")
  output: 
    success=temp(output("tmp/langdetect_{part}.success.txt")),
    fail=temp(output("tmp/langdetect_{part}.fail.txt")),
    doc_count=temp(output("tmp/langdetect_{part}.count.txt"))
  shell: "{input.bin} -i {input.data} -s {output.success} \
    -f {output.fail} -c {output.doc_count} -l {config[language]} -t {config[whatlang_threashold]}"

rule generate_ratios:
  input: 
    data=output("tmp/langdetect_{part}.success.txt"),
    bin="scripts/compute_ratios/target/release/compute_ratios",
    stopwords=config["ratio_file_stop_words"]
  output: temp(output("tmp/ratios_{part}.parquet"))
  shell: r"""
    {input.bin} --in {input.data} --out {output} --stop {input.stopwords}
  """

rule apply_svm:
  input: 
    data=output("tmp/ratios_{part}.parquet"),
    model=output(config['svm_file_model']),
  output: 
    clean=temp(output("tmp/svm_{part}.clean.txt")),
    dirt=temp(output("tmp/svm_{part}.dirt.txt"))
  conda: "envs/svm.yaml"
  shell: r"""
    scripts/apply_SVM.py --model {input.model} --ratio {input.data} \
      --out {output.clean} --dirt {output.dirt}
  """

rule merge_files:
  input: 
    clean=expand(output("tmp/svm_{part}.clean.txt"), part=range(1,config['num_files']+1)),
    doc_count=expand(output("tmp/langdetect_{part}.count.txt"), part=range(1,config['num_files']+1)),
    fail=expand(output("tmp/langdetect_{part}.fail.txt"), part=range(1,config['num_files']+1)),
    dirt_svm=expand(output("tmp/svm_{part}.dirt.txt"), part=range(1,config['num_files']+1)),
    dirt_filter=expand(output("tmp/filtered_{part}.dirt.txt"), part=range(1,config['num_files']+1))
  output: 
    clean=output("filtered.txt"),
    fail=output("trash/langdetect.txt"),
    doc_count=output("count.txt"),
    dirt_svm=output("trash/svm.txt"),
    dirt_filter=output("trash/filter.txt")
  shell: r"""
    cat {input.clean} > {output.clean}
    awk '{{print $0}}' {input.doc_count} > {output.doc_count}
    cat {input.fail} > {output.fail}
    cat {input.dirt_filter} > {output.dirt_filter}
    cat {input.dirt_svm} > {output.dirt_svm}
  """
